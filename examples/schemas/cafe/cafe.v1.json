{
  "type": "object",
  "properties": {
    "kind": {
      "type": "string",
      "title": "Kind",
      "description": "Kind identifies this configuration type.",
      "const": "Config"
    },
    "metadata": {
      "$ref": "#/$defs/Metadata",
      "title": "Metadata",
      "description": "Metadata contains identifying information about the cafe."
    },
    "spec": {
      "$ref": "#/$defs/Spec",
      "title": "Spec",
      "description": "Spec contains the cafe specification."
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Hours": {
      "type": "object",
      "properties": {
        "open": {
          "type": "string",
          "title": "Open",
          "description": "Open is the opening time in HH:MM format (24-hour).",
          "default": "07:00",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"
        },
        "close": {
          "type": "string",
          "title": "Close",
          "description": "Close is the closing time in HH:MM format (24-hour).",
          "default": "19:00",
          "pattern": "^([01]?[0-9]|2[0-3]):[0-5][0-9]$"
        },
        "days": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "type": "string",
            "enum": [
              "monday",
              "tuesday",
              "wednesday",
              "thursday",
              "friday",
              "saturday",
              "sunday"
            ]
          },
          "title": "Days",
          "description": "Days lists the days of operation."
        }
      },
      "description": "Hours defines operating hours for the cafe.",
      "required": [
        "open",
        "close",
        "days"
      ],
      "additionalProperties": false
    },
    "Menu": {
      "type": "object",
      "properties": {
        "items": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "$ref": "#/$defs/MenuItem"
          },
          "title": "Items",
          "description": "Items is the list of menu items.",
          "minItems": 1
        }
      },
      "description": "Menu defines the cafe's menu offerings.",
      "required": [
        "items"
      ],
      "additionalProperties": false
    },
    "MenuItem": {
      "type": "object",
      "properties": {
        "available": {
          "title": "Available",
          "description": "Available indicates whether the item is currently available.",
          "default": true,
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "name": {
          "type": "string",
          "title": "Name",
          "description": "Name is the name of the menu item.",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "title": "Category",
          "description": "Category is the type of item.",
          "enum": [
            "coffee",
            "tea",
            "pastry",
            "sandwich"
          ]
        },
        "description": {
          "type": "string",
          "title": "Description",
          "description": "Description provides additional details about the item."
        },
        "tags": {
          "type": [
            "null",
            "array"
          ],
          "items": {
            "type": "string"
          },
          "title": "Tags",
          "description": "Tags are optional labels for the item."
        },
        "price": {
          "type": "number",
          "title": "Price",
          "description": "Price is the cost of the item in dollars.",
          "minimum": 0
        }
      },
      "description": "MenuItem represents a single item on the menu.",
      "required": [
        "name",
        "category",
        "price"
      ],
      "additionalProperties": false
    },
    "Metadata": {
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "title": "Name",
          "description": "Name is the name of the cafe.",
          "minLength": 1,
          "maxLength": 100
        },
        "description": {
          "type": "string",
          "title": "Description",
          "description": "Description provides additional details about the cafe."
        }
      },
      "description": "Metadata contains identifying information about the cafe.",
      "required": [
        "name"
      ],
      "additionalProperties": false
    },
    "Settings": {
      "type": "object",
      "properties": {
        "wifi": {
          "title": "WiFi",
          "description": "WiFi indicates whether WiFi is available.",
          "default": true,
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "mobile_ordering": {
          "title": "Mobile Ordering",
          "description": "MobileOrdering indicates whether mobile ordering is enabled.",
          "default": false,
          "anyOf": [
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "custom_options": {
          "type": [
            "null",
            "object"
          ],
          "title": "Custom Options",
          "description": "CustomOptions contains additional custom settings.",
          "additionalProperties": {
            "type": "string"
          }
        },
        "theme": {
          "type": "string",
          "title": "Theme",
          "description": "Theme is the UI theme for digital displays.",
          "default": "auto",
          "enum": [
            "light",
            "dark",
            "auto"
          ]
        }
      },
      "description": "Settings contains optional cafe settings.",
      "additionalProperties": false
    },
    "Spec": {
      "type": "object",
      "properties": {
        "sla": {
          "type": "string",
          "title": "SLA",
          "description": "SLA is the service level agreement duration for order fulfillment.\nDefaults to 15 minutes.",
          "default": "15m",
          "pattern": "^(\\d+d)?(\\d+h)?(\\d+m)?(\\d+s)?$"
        },
        "settings": {
          "title": "Settings",
          "description": "Settings contains optional cafe settings.",
          "anyOf": [
            {
              "$ref": "#/$defs/Settings"
            },
            {
              "type": "null"
            }
          ]
        },
        "hours": {
          "$ref": "#/$defs/Hours",
          "title": "Hours",
          "description": "Hours defines operating hours."
        },
        "menu": {
          "$ref": "#/$defs/Menu",
          "title": "Menu",
          "description": "Menu defines the cafe's menu."
        },
        "staff": {
          "$ref": "#/$defs/Staff",
          "title": "Staff",
          "description": "Staff defines staffing requirements."
        }
      },
      "description": "Spec is the cafe specification.",
      "required": [
        "hours",
        "menu",
        "staff"
      ],
      "additionalProperties": false
    },
    "Staff": {
      "type": "object",
      "properties": {
        "baristas": {
          "type": "integer",
          "title": "Baristas",
          "description": "Baristas is the number of baristas on shift.",
          "default": 2,
          "minimum": 1,
          "maximum": 10
        },
        "managers": {
          "type": "integer",
          "title": "Managers",
          "description": "Managers is the number of managers on shift.",
          "default": 1,
          "minimum": 1
        }
      },
      "description": "Staff defines staffing requirements.",
      "required": [
        "baristas",
        "managers"
      ],
      "additionalProperties": false
    }
  },
  "description": "Config is the root cafe configuration.\nCreate instances with [NewConfig].",
  "required": [
    "kind",
    "metadata",
    "spec"
  ],
  "additionalProperties": false
}